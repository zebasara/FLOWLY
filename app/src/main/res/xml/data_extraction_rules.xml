<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Excluir DataStore (sesión y preferencias por dispositivo) -->
        <exclude domain="file" path="datastore/flowly_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <!-- Excluir preferencias de dispositivo en transferencias -->
        <exclude domain="file" path="datastore/flowly_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
