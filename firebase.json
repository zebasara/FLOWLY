{
  "hosting": {
    "site": "flowly-move",
    "public": "admin",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/app-ads.txt",
        "headers": [
          { "key": "Content-Type", "value": "text/plain" }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/app",
        "destination": "https://play.google.com/store/apps/details?id=com.flowly.move",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/privacidad",
        "destination": "/privacidad.html"
      },
      {
        "source": "/admin",
        "destination": "/panel.html"
      },
      {
        "source": "/r/**",
        "destination": "/referral.html"
      }
    ]
  },
  "firestore": {
    "indexes": "firestore.indexes.json",
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}